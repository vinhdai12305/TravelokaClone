<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Traveloka Clone</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background-color: #f7f9fa;
      color: #03121a;
    }

    .flatpickr-calendar {
      border-radius: 15px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
      margin-top: 10px;
    }

    .dropdown {
      position: absolute;
      top: 60px;
      width: 100%;
      background: white;
      border: 1px solid #ddd;
      border-radius: 10px;
      z-index: 999;
    }

    .dropdown div {
      padding: 10px;
      cursor: pointer;
    }

    .dropdown div:hover {
      background: #f0f0f0;
    }
  </style>
</head>

<body>

<%- include('partials/header') %>

<div style="width: 100%; padding: 30px 80px;">
  <div style="position: relative; border-radius: 20px; overflow: hidden;">
    
    <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470"
         style="width:100%; height:400px; object-fit:cover;">

    <div style="
      position: absolute;
      bottom: 50px;
      left: 0;
      width: 100%;
      padding: 40px;
      background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
      color: white;
    ">
      <h1 style="font-size:40px; font-weight:700;">
         Find Cheap Flights & Airline Deals
      </h1>
        <p style="font-size:18px; margin-top:10px;">
          Book your next flight with us and save big on airfare.
        </p>
    </div>



  </div>
</div>

<div style="
    width: 100%; 
    margin-top: -100px; 
    padding: 0 80px; 
    position: relative; 
    z-index: 10; 
    margin-bottom: 40px;">

      
<!-- SEARCH BOX -->
<div style="
  background:white;
  padding:25px;
  border-radius:25px;
  box-shadow:0 20px 50px rgba(0,0,0,0.15);
">

  <!-- OPTIONS -->
  <div style="
    display:flex;
    align-items:center;
    margin-bottom:20px;
  ">

    <!-- LEFT -->
    <div style="display:flex; gap:10px;">
      <button style="background:#2196f3;color:white;border:none;padding:8px 16px;border-radius:20px;">One-way</button>
      <button style="background:#eee;border:none;padding:8px 16px;border-radius:20px;">Round-trip</button>
    </div>

    <!-- RIGHT -->
    <div style="margin-left:auto; display:flex; align-items:center; gap:25px; font-size:14px; color:#0e3a60">

      <!-- PASSENGER -->
      <div>1 Adult, 0 Child, 0 Infant (on lap) ▼</div>

      <!-- ECONOMY -->
      <div>Economy ▼</div>

    </div>

  </div>

  <!-- FORM -->
  <div style="display:flex; gap:15px; align-items:center;">

    <!-- FROM -->
    <div style="
      flex:1;
      border:1px solid #ddd;
      border-radius:12px;
      padding:12px;
      position:relative;
    ">
      <div style="font-size:13px; color:#777;">From</div>
      <input placeholder="City or airport"
        style="width:100%; border:none; outline:none; font-size:15px;">
    </div>

    <!-- SWAP -->
    <div style="
      background:#2196f3;
      color:white;
      width:40px;
      height:40px;
      display:flex;
      align-items:center;
      justify-content:center;
      border-radius:50%;
      cursor:pointer;
    ">⇄</div>

    <!-- TO -->
    <div style="
      flex:1;
      border:1px solid #ddd;
      border-radius:12px;
      padding:12px;
    ">
      <div style="font-size:13px; color:#777;">To</div>
      <input placeholder="City or airport"
        style="width:100%; border:none; outline:none; font-size:15px;">
    </div>

    <!-- DEPARTURE -->
    <div style="
      flex:1;
      border:1px solid #ddd;
      border-radius:12px;
      padding:12px;
    ">
      <div style="font-size:13px; color:#777;">Departure date</div>
      <input placeholder="Select date"
        style="width:100%; border:none; outline:none;">
    </div>

    <!-- RETURN -->
    <div style="
      flex:1;
      border:1px solid #ddd;
      border-radius:12px;
      padding:12px;
      background:#f5f5f5;
    ">
      <div style="font-size:13px; color:#aaa;">Return Date</div>
      <input placeholder="Select return date"
        style="width:100%; border:none; outline:none; background:transparent;">
    </div>

    <!-- BUTTON -->
    <button style="
      background:#ff5e1f;
      color:white;
      border:none;
      padding: 15px 30px;
      font-size: 16px;
      border-radius:30px;
      font-weight:bold;
      cursor:pointer;
      white-space:nowrap;
    ">
      Search Flights
    </button>

  </div>

  <!-- EXTRA LINE -->
  <div style="margin-top:15px; color:#1e88e5; font-size:14px;">
    📍 Feeling spontaneous? Search flights to anywhere!
  </div>

</div>

<!-- SCRIPT -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
// DATE PICKER
flatpickr("#date", {
  dateFormat: "Y-m-d"
});

// FETCH AIRPORT
async function fetchAirports(query) {
  if (!query) return [];
  const res = await fetch(`/flight/search-airport?q=${query}`);
  return await res.json();
}

// RENDER
function renderList(list, box, input) {
  box.innerHTML = "";

  list.forEach(item => {
    const div = document.createElement("div");
    div.innerHTML = `<b>${item.code}</b> - ${item.name}`;

    div.onclick = () => {
      input.value = `${item.city} (${item.code})`;
      box.innerHTML = "";
    };

    box.appendChild(div);
  });
}

// INPUT FROM
const from = document.getElementById("from");
const fromList = document.getElementById("from-list");

from.addEventListener("input", async () => {
  const data = await fetchAirports(from.value);
  renderList(data, fromList, from);
});

// INPUT TO
const to = document.getElementById("to");
const toList = document.getElementById("to-list");

to.addEventListener("input", async () => {
  const data = await fetchAirports(to.value);
  renderList(data, toList, to);
});

// SWAP
document.getElementById("swap").onclick = () => {
  const temp = from.value;
  from.value = to.value;
  to.value = temp;
};
</script>


</body>
</html>