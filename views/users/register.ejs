<form class="auth-form <%= (isFormActive && activeForm === 'register') ? 'active' : '' %>" id="register-form" action="/users/register" method="POST" style="display: <%= (isFormActive && activeForm === 'register') ? 'block' : 'none' %>;">
  <div class="field">
    <input type="text" name="name" placeholder="Họ và tên" value="<%= typeof formData !== 'undefined' && formData ? formData.name : '' %>" required style="width: 100%; padding: 10px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #ccc;"/>
  </div>
  <div class="field">
    <input type="email" name="email" placeholder="Email" value="<%= typeof formData !== 'undefined' && formData ? formData.email : '' %>" required style="width: 100%; padding: 10px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #ccc;"/>
    <% if (typeof registerError !== 'undefined' && registerError) { %>
      <div class="error-message" style="color: red; font-size: 12px; margin-bottom: 5px;"><%= registerError %></div>
    <% } %>
  </div>
  <div class="field">
    <input type="password" id="reg-password" name="password" placeholder="Mật khẩu" required minlength="6" style="width: 100%; padding: 10px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #ccc;"/>
  </div>
  <div class="field">
    <input type="password" id="reg-confirm-password" name="confirmPassword" placeholder="Nhập lại mật khẩu" required style="width: 100%; padding: 10px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #ccc;"/>
    <% if (typeof passwordError !== 'undefined' && passwordError) { %>
      <div class="error-message" style="color: red; font-size: 12px; margin-bottom: 5px;"><%= passwordError %></div>
    <% } %>
  </div>
  <button class="btn btn-primary btn-block" type="submit" style="width: 100%; border-radius: 8px;">Đăng ký tài khoản</button>
</form>