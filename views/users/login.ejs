<div class="auth-form active" id="login-form">
  <form action="/users/login" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
    <input type="email" name="email" placeholder="Email của bạn" required style="padding: 10px; border-radius: 5px; border: 1px solid #ccc;">
    <input type="password" name="password" placeholder="Mật khẩu" required style="padding: 10px; border-radius: 5px; border: 1px solid #ccc;">
    <button type="submit" class="btn btn-primary" style="padding: 10px; border-radius: 5px; font-weight: bold;">Đăng nhập</button>
  </form>
</div>