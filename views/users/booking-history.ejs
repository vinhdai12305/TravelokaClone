<%- include('../partials/header') %>

<style>
  .page-container { max-width: 900px; margin: 40px auto; padding: 0 20px; }
  .page-title { color: #003580; margin-bottom: 25px; font-size: 24px; }
  .hotel-card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: flex; gap: 20px; margin-bottom: 20px; border: 1px solid #eaeaea; }
  .hotel-img { width: 220px; height: 150px; object-fit: cover; border-radius: 8px; }
  .hotel-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
  .status-badge { background: #e6f4ea; color: #137333; padding: 5px 10px; border-radius: 20px; font-size: 12px; font-weight: bold; height: fit-content; }
  .hotel-price { font-size: 22px; font-weight: bold; color: #ff5e1f; }
  .btn-action { padding: 8px 16px; background: white; border: 1px solid #003580; color: #003580; border-radius: 6px; font-weight: 600; cursor: pointer; transition: 0.2s; }
  .btn-action:hover { background: #003580; color: white; }
</style>

<div class="page-container">
  <h2 class="page-title"><i class="fas fa-bed"></i> Lịch sử đặt phòng của <%= user ? user.username : 'bạn' %></h2>

  <div class="hotel-card">
    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Hotel" class="hotel-img">
    
    <div class="hotel-info">
      <div>
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
          <h3 style="color: #333; font-size: 18px; margin-bottom: 8px;">InterContinental Danang Sun Peninsula Resort</h3>
          <span class="status-badge">Đã hoàn tất</span>
        </div>
        <p style="color: #666; font-size: 14px; margin-bottom: 8px;">
          <i class="fas fa-map-marker-alt" style="color: #003580; margin-right: 5px;"></i> Bán đảo Sơn Trà, Đà Nẵng
        </p>
        <div style="background: #f9f9f9; padding: 10px; border-radius: 6px; display: inline-block;">
          <p style="color: #555; font-size: 14px; font-weight: bold;">
            <i class="far fa-calendar-alt" style="margin-right: 5px;"></i> 15/05/2026 - 18/05/2026
          </p>
          <p style="color: #666; font-size: 13px; margin-top: 4px;">1 Phòng Superior, 2 Người lớn</p>
        </div>
      </div>
      
      <div style="display: flex; justify-content: space-between; align-items: flex-end;">
        <p class="hotel-price">8.500.000 VND</p>
        <button class="btn-action">Đặt lại</button>
      </div>
    </div>
  </div>
</div>
</body>
</html>