<%- include('../partials/header') %>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Traveloka Clone</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background-color: #f7f9fa;
      padding: 0;
      margin: 0;
      color: #03121a;
    }

    .flatpickr-calendar {
      border-radius: 15px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
      top: 100% !important;
      left: 0 !important;
      margin-top: 10px;
    }
  </style>
</head>

<body>

<!-- HERO BANNER -->
<div style="width: 100%; padding: 30px 80px;">
  <div style="position: relative; border-radius: 20px; overflow: hidden;">
    
    <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e"
         style="width:100%; height:400px; object-fit:cover;">

    <div style="
      position: absolute;
      bottom: 50px;
      left: 0;
      width: 100%;
      padding: 40px;
      background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
      color: white;
    ">
      <h1 style="font-size:40px; font-weight:700;">
        Where to next? Book your next hotel for less
      </h1>
      <p style="font-size: 20px; margin-top:10px;">
        Discover hotels, villas, resorts and more.
      </p>
    </div>

  </div>
</div>

<!-- SEARCH BOX -->
<div style="
  width: 100%;
  margin-top: -100px;
  padding: 0 80px;
  position: relative;
  z-index: 10;
  margin-bottom: 40px;
">

  <div style="
    background: white;
    padding: 30px;
    border-radius: 25px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    display: flex;
    gap: 25px;
    align-items: flex-end;
  ">

    <!-- LOCATION -->
    <div style="flex:1; display:flex; flex-direction:column; gap:6px; position:relative;">
      <div style="font-size:13px; color:#000000; font-weight: 600;">
        City, destination, or hotel name
      </div>

      <input id="searchInput" type="text" placeholder="City, hotel, place to go" style="
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: 1px solid #ddd;
        font-size: 14px;
      ">

      <div id="dropdown" style="
        position:absolute;
        top:75px;
        left:0;
        width:130%;
        background:white;
        border-radius:12px;
        box-shadow:0 15px 40px rgba(0,0,0,0.15);
        display:none;
        z-index:999;
        max-height: 400px;
        overflow-y: auto;
      "></div>
    </div>

    <!-- DATE -->
    <div style="flex:1; display:flex; flex-direction:column; gap:6px; position:relative;">
      <div style="font-size:13px; color:#000000; font-weight: 600;">
        Check-in & Check-out Dates
      </div>

      <input id="dateInput" type="text" placeholder="Select dates" style="
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: 1px solid #ddd;
        font-size: 14px;
      ">
    </div>

    <!-- GUEST -->
    <div style="flex:1; display:flex; flex-direction:column; gap:6px; position:relative;">
      <div style="font-size:13px; color:#000000; font-weight: 600;">
        Guests and Rooms
      </div>

      <!-- INPUT -->
      <input id="guestInput" readonly value="2 Adult(s), 0 Child, 1 Room" style="
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: 1px solid #ddd;
        cursor: pointer;
        font-size: 14px;
      ">

      <!-- DROPDOWN -->
      <div id="guestDropdown" style="
        position:absolute;
        top: 75px;
        left:0;
        width:100%;
        background:white;
        border-radius:12px;
        box-shadow:0 15px 40px rgba(0,0,0,0.15);
        padding:20px;
        display:none;
        z-index:999;
      ">
        
        <!-- ADULT -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
          <div style="font-weight: 600;">Adult</div>
          <div style="display:flex; align-items:center; gap:15px;">
            <button onclick="change('adult', -1)" style="width: 30px; height: 30px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">-</button>
            <span id="adult" style="min-width: 20px; text-align: center;">2</span>
            <button onclick="change('adult', 1)" style="width: 30px; height: 30px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">+</button>
          </div>
        </div>

        <!-- CHILDREN -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
          <div style="font-weight: 600;">Children</div>
          <div style="display:flex; align-items:center; gap:15px;">
            <button onclick="change('child', -1)" style="width: 30px; height: 30px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">-</button>
            <span id="child" style="min-width: 20px; text-align: center;">0</span>
            <button onclick="change('child', 1)" style="width: 30px; height: 30px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">+</button>
          </div>
        </div>

        <!-- ROOM -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
          <div style="font-weight: 600;">Room</div>
          <div style="display:flex; align-items:center; gap:15px;">
            <button onclick="change('room', -1)" style="width: 30px; height: 30px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">-</button>
            <span id="room" style="min-width: 20px; text-align: center;">1</span>
            <button onclick="change('room', 1)" style="width: 30px; height: 30px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">+</button>
          </div>
        </div>

        <!-- BUTTON -->
        <div style="margin-top:20px; text-align:right;">
          <button onclick="closeGuest()" style="
            background:#0071c2;
            color:white;
            border:none;
            padding:10px 20px;
            border-radius:20px;
            cursor:pointer;
            font-weight: 600;
          ">
            Done
          </button>
        </div>

      </div>
    </div>

    <!-- SEARCH BUTTON -->
    <div style="display:flex; align-items:flex-end;">
      <button style="
        background: #0071c2;
        color: white;
        border: none;
        padding: 16px 32px;
        border-radius: 40px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.3s;
      " onmouseover="this.style.background='#005a9c'" onmouseout="this.style.background='#0071c2'">
        Search
      </button>
    </div>

  </div>
</div>

<!-- GỌI FILE hotelLists.ejs -->
<%- include('./hotelLists') %>

<!-- SEARCH SCRIPT -->
<script>
const input = document.getElementById('searchInput');
const dropdown = document.getElementById('dropdown');

input.addEventListener('input', async () => {
  const q = input.value;

  if (!q) {
    dropdown.style.display = 'none';
    return;
  }

  try {
    const res = await fetch(`/locations/search?q=${q}`);
    const data = await res.json();

    if (data.length === 0) {
      dropdown.style.display = 'none';
      return;
    }

    dropdown.innerHTML = '';

    data.forEach(loc => {
      const item = document.createElement('div');

      item.style.padding = '15px';
      item.style.borderBottom = '1px solid #eee';
      item.style.cursor = 'pointer';
      item.style.display = 'flex';
      item.style.justifyContent = 'space-between';
      item.style.alignItems = 'center';

      item.onmouseover = () => item.style.background = '#f5f7fa';
      item.onmouseout = () => item.style.background = 'white';

      item.innerHTML = `
        <div>
          <div style="font-weight:700; font-size:14px;">
            ${loc.name}
          </div>
          <div style="font-size:14px; color:#777; margin-top:6px;">
            ${loc.description}, ${loc.country}
          </div>
        </div>

        <div style="text-align:right;">
          <div style="
            background:#e6f0ff;
            color:#0071c2;
            padding:4px 10px;
            border-radius:20px;
            font-size:11px;
            display:flex;
            align-items:center;
            justify-content:center;
            height:20px;
            min-width:45px;
          ">
            City
          </div>

          <div style="font-size:13px; color:#666; margin-top:6px;">
            ${loc.hotelsCount || 0} hotels nearby
          </div>
        </div>
      `;

      item.onclick = () => {
        input.value = loc.name;
        dropdown.style.display = 'none';
      };

      dropdown.appendChild(item);
    });

    dropdown.style.display = 'block';
  } catch (error) {
    console.error('Lỗi tìm kiếm:', error);
  }
});
</script>

<!-- FLATPICKR -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
flatpickr("#dateInput", {
  mode: "range",
  dateFormat: "D, d M Y",
  minDate: "today",
  showMonths: 2,
  position: "below",
  static: true
});
</script>

<script>
const guestInput = document.getElementById('guestInput');
const guestDropdown = document.getElementById('guestDropdown');

let state = {
  adult: 2,
  child: 0,
  room: 1
};

// Mở dropdown
guestInput.onclick = () => {
  guestDropdown.style.display = 'block';
};

// Đóng dropdown
function closeGuest() {
  guestDropdown.style.display = 'none';
}

// Thay đổi số lượng
function change(type, value) {
  state[type] += value;

  if (type === 'adult' && state[type] < 1) state[type] = 1;
  if (type !== 'adult' && state[type] < 0) state[type] = 0;

  document.getElementById(type).innerText = state[type];

  updateInput();
}

// Update input value
function updateInput() {
  guestInput.value = `${state.adult} Adult(s), ${state.child} Child, ${state.room} Room`;
}
</script>

</body>
</html>