<%- include('../partials/header') %>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Khách sạn phố biển - Traveloka Clone</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary-blue: #0194f3;
            --secondary-blue: #e8f3ff;
            --orange-main: #ff5e1f;
            --text-dark: #03121a;
            --text-gray: #687176;
            --bg-light: #f7f9fa;
            --border-soft: #e6eaed;
            --shadow: 0 4px 12px rgba(3, 18, 26, 0.08);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.5;
        }

        /* BREADCRUMB */
        .breadcrumb-container {
            background: white;
            padding: 12px 40px;
            border-bottom: 1px solid var(--border-soft);
        }
        .breadcrumb {
            max-width: 1200px;
            margin: 0 auto;
            font-size: 13px;
        }
        .breadcrumb a { color: var(--primary-blue); text-decoration: none; font-weight: 500; }
        .breadcrumb span { color: var(--text-gray); }

        .main-container {
            display: flex;
            gap: 24px;
            padding: 24px 40px;
            max-width: 1240px;
            margin: 0 auto;
        }

        /* SIDEBAR NÂNG CẤP */
        .sidebar { width: 280px; flex-shrink: 0; }
        
        .sidebar-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid var(--border-soft);
        }

        .promo-banner {
            background: linear-gradient(135deg, #0194f3, #0071c2);
            color: white;
            border: none;
        }
        .promo-banner h4 { font-size: 15px; margin-bottom: 6px; }
        .promo-banner p { font-size: 12px; opacity: 0.9; }

        .sidebar-title {
            font-weight: 700;
            font-size: 15px;
            margin-bottom: 16px;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-section {
            border-bottom: 1px solid var(--border-soft);
            padding-bottom: 16px;
            margin-bottom: 16px;
        }
        .filter-section:last-child { border: none; margin: 0; padding: 0; }

        .price-box {
            background: #f2f3f3;
            border-radius: 8px;
            padding: 10px;
            display: flex;
            align-items: center;
            margin-bottom: 10px;
        }
        .price-box input {
            background: transparent;
            border: none;
            outline: none;
            width: 100%;
            font-size: 13px;
            font-weight: 600;
        }

        .checkbox-label {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
            cursor: pointer;
            font-size: 14px;
            transition: color 0.2s;
        }
        .checkbox-label:hover { color: var(--primary-blue); }
        .checkbox-label input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--primary-blue);
        }

        /* CONTENT */
        .content { flex: 1; }

        .header-summary {
            background: white;
            padding: 20px 24px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid var(--border-soft);
        }
        .header-summary h1 { font-size: 22px; font-weight: 700; }
        .header-summary p { font-size: 14px; color: var(--text-gray); }

        .sort-select {
            padding: 10px 16px;
            border-radius: 20px;
            border: 1px solid #ced4da;
            font-size: 14px;
            color: var(--primary-blue);
            font-weight: 600;
            cursor: pointer;
        }

        /* HOTEL ITEM RE-DESIGN */
        .hotel-card {
            background: white;
            border-radius: 16px;
            display: flex;
            margin-bottom: 24px;
            overflow: hidden;
            border: 1px solid var(--border-soft);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
            color: inherit;
        }
        .hotel-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow);
            border-color: var(--primary-blue);
        }

        .hotel-media {
            width: 280px;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .main-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 12px;
        }
        .thumb-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }
        .thumb-row img {
            width: 100%;
            height: 45px;
            object-fit: cover;
            border-radius: 6px;
            border: 1px solid transparent;
        }

        .hotel-details {
            flex: 1;
            padding: 20px;
            border-right: 1px solid var(--border-soft);
        }
        .badge-row { display: flex; gap: 8px; margin-bottom: 10px; }
        .type-badge {
            background: var(--secondary-blue);
            color: var(--primary-blue);
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .hotel-title { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
        
        .rating-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }
        .rating-chip {
            background: var(--primary-blue);
            color: white;
            padding: 4px 10px;
            border-radius: 8px 8px 8px 0;
            font-weight: 700;
            font-size: 14px;
        }
        .rating-label { color: var(--primary-blue); font-weight: 600; font-size: 14px; }

        .location-info {
            font-size: 13px;
            color: var(--text-gray);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .amenity-list {
            display: flex;
            gap: 15px;
            color: var(--text-gray);
            font-size: 13px;
            border-top: 1px solid var(--border-soft);
            padding-top: 15px;
        }

        .price-section {
            width: 240px;
            padding: 24px;
            background: #fcfdfe;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            text-align: right;
        }
        .strike-price {
            text-decoration: line-through;
            color: var(--text-gray);
            font-size: 13px;
        }
        .actual-price {
            color: var(--orange-main);
            font-size: 26px;
            font-weight: 800;
            margin: 4px 0;
        }
        .tax-info { font-size: 12px; color: var(--text-gray); margin-bottom: 15px; }

        .select-btn {
            background: var(--orange-main);
            color: white;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }
        .select-btn:hover { background: #e6541a; }

        .booking-count {
            color: #d32f2f;
            font-size: 11px;
            font-weight: 600;
            margin-top: 10px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 4px;
        }

        /* EMPTY STATE */
        .empty-state {
            background: white;
            padding: 80px;
            text-align: center;
            border-radius: 16px;
            border: 1px solid var(--border-soft);
        }
    </style>
</head>

<body>

<div class="breadcrumb-container">
    <div class="breadcrumb">
        <a href="/">Trang chủ</a> / <span>Khách sạn</span>
    </div>
</div>

<div class="main-container">
    <div class="sidebar">
        <div class="sidebar-card promo-banner">
            <h4>Ưu đãi cho bạn mới! 🎁</h4>
            <p>Sử dụng mã <b>TVLKBANMOI</b> giảm ngay 100.000 VND.</p>
        </div>

        <div class="sidebar-card">
            <div class="filter-section">
                <div class="sidebar-title"><i class="fas fa-tags"></i> Khoảng giá</div>
                <div class="price-box">
                    <span style="font-size: 12px; margin-right: 5px;">VND</span>
                    <input type="text" value="0">
                </div>
                <div class="price-box">
                    <span style="font-size: 12px; margin-right: 5px;">VND</span>
                    <input type="text" value="24.000.000">
                </div>
                <input type="range" style="width: 100%; accent-color: var(--primary-blue);" min="0" max="24000000">
            </div>

            <div class="filter-section">
                <div class="sidebar-title"><i class="fas fa-star"></i> Hạng sao</div>
                <% [5,4,3].forEach(star => { %>
                <label class="checkbox-label">
                    <input type="checkbox">
                    <span>
                        <% for(let i=0; i<star; i++) { %>
                            <i class="fas fa-star" style="color: #febb02; font-size: 12px;"></i>
                        <% } %>
                    </span>
                </label>
                <% }) %>
            </div>

            <div class="filter-section">
                <div class="sidebar-title"><i class="fas fa-list-ul"></i> Tiện nghi</div>
                <label class="checkbox-label"><input type="checkbox"> <span>Hồ bơi</span></label>
                <label class="checkbox-label"><input type="checkbox"> <span>Wifi miễn phí</span></label>
                <label class="checkbox-label"><input type="checkbox"> <span>Nhà hàng</span></label>
                <label class="checkbox-label"><input type="checkbox"> <span>Dịch vụ Spa</span></label>
            </div>
        </div>
    </div>

    <div class="content">
    <div class="header-summary" style="border-radius: 16px; border: 1px solid var(--border-soft); box-shadow: var(--shadow);">
        <div>
            <h1 style="
                font-size: 20px; 
                font-weight: 700; 
                color: var(--text-dark);
                position: relative;
                display: inline-block;
                padding-bottom: 8px;
            ">
                Xem qua những khách sạn nổi bật và các đánh giá gần đây
                <span style="
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 800px; /* Độ dài đường kẻ */
                    height: 4px; /* Độ dày */
                    background: linear-gradient(90deg, var(--primary-blue), transparent);
                    border-radius: 2px;
                "></span>
            </h1>
        </div>
        <select class="sort-select">
            <option>Sắp xếp: Phổ biến nhất</option>
            <option>Giá thấp nhất</option>
            <option>Điểm đánh giá</option>
        </select>
    </div>
        <% if (typeof hotels !== 'undefined' && hotels.length > 0) { %>
            <% hotels.forEach((hotel) => { %>
                <a href="/hotels/<%= hotel._id %>" class="hotel-card">
                    <div class="hotel-media">
                        <img src="<%= hotel.image || '/images/default-hotel.jpg' %>" class="main-img" alt="hotel">
                        <div class="thumb-row">
                            <img src="<%= hotel.image %>" alt="thumb">
                            <img src="<%= hotel.image %>" alt="thumb">
                            <img src="<%= hotel.image %>" alt="thumb">
                            <img src="<%= hotel.image %>" alt="thumb">
                        </div>
                    </div>

                    <div class="hotel-details">
                        <div class="badge-row">
                            <span class="type-badge">Khách sạn</span>
                            <div style="color: #febb02; font-size: 12px;">
                                <% for(let i=0; i < (hotel.stars || 0); i++) { %>
                                    <i class="fas fa-star"></i>
                                <% } %>
                            </div>
                        </div>

                        <h2 class="hotel-title"><%= hotel.name %></h2>
                        
                        <div class="rating-wrapper">
                            <div class="rating-chip">
                                <i class="fas fa-award"></i> <%= hotel.rating || 8.5 %>
                            </div>
                            <span class="rating-label">Tuyệt vời</span>
                            <span style="color: var(--text-gray); font-size: 12px;">(1,420 đánh giá)</span>
                        </div>

                        <div class="location-info">
                            <i class="fas fa-map-marker-alt" style="color: var(--primary-blue);"></i> 
                            <%= hotel.location || 'Bali, Indonesia' %>
                        </div>

                        <div class="amenity-list">
                            <span><i class="fas fa-wifi"></i> Wifi</span>
                            <span><i class="fas fa-swimming-pool"></i> Hồ bơi</span>
                            <span><i class="fas fa-utensils"></i> Nhà hàng</span>
                            <span><i class="fas fa-spa"></i> Spa</span>
                        </div>
                    </div>

                    <div class="price-section">
                        <div style="font-size: 12px; color: var(--text-gray);">Giá mỗi đêm từ</div>
                        <% if (hotel.discountPrice && hotel.discountPrice > 0) { %>
                            <div class="strike-price"><%= (hotel.discountPrice * 1.2).toLocaleString('vi-VN') %> VND</div>
                            <div class="actual-price"><%= hotel.discountPrice.toLocaleString('vi-VN') %> <span style="font-size: 14px;">VND</span></div>
                        <% } else { %>
                            <div class="actual-price"><%= (hotel.price || 0).toLocaleString('vi-VN') %> <span style="font-size: 14px;">VND</span></div>
                        <% } %>
                        <div class="tax-info">Đã bao gồm thuế & phí</div>
                        
                        <button class="select-btn">Chọn phòng</button>
                        
                        <div class="booking-count">
                            <i class="fas fa-fire"></i> Đang được quan tâm
                        </div>
                    </div>
                </a>
            <% }); %>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-search" style="font-size: 48px; color: var(--border-soft); margin-bottom: 20px;"></i>
                <h3 style="color: var(--text-gray);">Không tìm thấy khách sạn phù hợp</h3>
                <p style="color: var(--text-gray); font-size: 14px;">Vui lòng thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
            </div>
        <% } %>
    </div>
</div>

</body>
</html>