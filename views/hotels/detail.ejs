<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= hotel.name %></title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
    font-family: 'Segoe UI', sans-serif;
    background:#f5f7fa;
}

/* Container */
.main-wrapper {
    max-width:1100px;
    margin:30px auto;
    padding:0 20px;
}

/* Breadcrumb */
.breadcrumbs {
    font-size:13px;
    color:#0194f3;
    margin-bottom:15px;
    font-weight:600;
}

/* CARD */
.hotel-card {
    background:#fff;
    border-radius:18px;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
    overflow:hidden;
    margin-bottom:20px;
}

/* GALLERY */
.gallery-container {
    display:flex;
    gap:10px;
    padding:20px;
    height:420px;
}

.img-large {
    flex:2;
    border-radius:14px;
    overflow:hidden;
}

.img-large img {
    width:100%;
    height:100%;
    object-fit:cover;
}

.img-grid-small {
    flex:1.2;
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
}

.img-grid-small img {
    width:100%;
    height:100%;
    object-fit:cover;
    border-radius:12px;
}

/* INFO */
.info-container {
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:0 20px 20px;
}

.hotel-title {
    font-size:24px;
    font-weight:700;
    margin-bottom:5px;
}

.hotel-tags {
    display:flex;
    gap:10px;
    align-items:center;
}

.badge {
    background:#e6f4ff;
    color:#0284c7;
    padding:4px 10px;
    border-radius:20px;
    font-size:12px;
}

.stars {
    color:#f59e0b;
}

/* PRICE */
.price-box {
    text-align:right;
}

.price-label {
    font-size:12px;
    color:#687176;
}

.price-val {
    font-size:28px;
    font-weight:800;
    color:#ff5e1f;
    margin:5px 0;
}

/* BUTTON */
.btn-select {
    background:#ff5e1f;
    color:white;
    border:none;
    padding:12px 26px;
    border-radius:10px;
    font-weight:700;
    cursor:pointer;
}

.btn-select:hover {
    background:#e04b12;
}

/* ALERT */
.alert {
    background:#e6f4ff;
    color:#0369a1;
    padding:14px 20px;
    border-radius:30px;
    margin-bottom:20px;
    font-weight:600;
}

/* DETAILS */
.details-grid {
    display:grid;
    grid-template-columns:1fr 1fr 1fr;
    gap:25px;
    background:#fff;
    padding:25px;
    border-radius:18px;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
}

.section-title {
    font-weight:700;
    margin-bottom:12px;
}

/* RATING */
.rating-score {
    font-size:28px;
    font-weight:800;
    color:#0194f3;
}

/* Nearby */
.area-item {
    display:flex;
    justify-content:space-between;
    margin-bottom:8px;
    font-size:14px;
}

/* Facilities */
.facility-item {
    display:flex;
    gap:10px;
    margin-bottom:10px;
}

.facility-item i {
    color:#0194f3;
}

/* Hover */
.hotel-card:hover {
    transform:translateY(-3px);
    transition:0.2s;
}
</style>
</head>

<body>

<%- include('../partials/header') %>

<div class="main-wrapper">

<!-- Breadcrumb -->
<div class="breadcrumbs">
    <%= hotel.location_breadcrumb || 'Hotel / Đà Nẵng' %>
</div>

<!-- CARD -->
<div class="hotel-card">

    <!-- GALLERY -->
    <div class="gallery-container">

        <div class="img-large">
            <img src="<%= hotel.images?.large || '/images/default.jpg' %>">
        </div>

        <div class="img-grid-small">
            <% (hotel.images?.small || []).forEach(function(img) { %>
                <img src="<%= img %>">
            <% }) %>
        </div>

    </div>

    <!-- INFO -->
    <div class="info-container">

        <div>
            <div class="hotel-title"><%= hotel.name %></div>

            <div class="hotel-tags">
                <span class="badge"><%= hotel.type || 'Khách sạn' %></span>

                <div class="stars">
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                </div>
            </div>
        </div>

        <div class="price-box">
            <div class="price-label">Price/room/night starts from</div>
            <div class="price-val"><%= hotel.price || '0' %> VND</div>
            <button class="btn-select">Select Room</button>
        </div>

    </div>

</div>

<!-- ALERT -->
<div class="alert">
    Don't miss out! Only 1 room(s) left for the lowest price.
</div>

<!-- DETAILS -->
<div class="details-grid">

    <!-- Rating -->
    <div>
        <div class="rating-score"><%= hotel.rating || 'N/A' %>/10</div>
        <div><%= hotel.rating_text || '' %></div>
    </div>

    <!-- Nearby -->
    <div>
        <div class="section-title">In the Area</div>
        <p><%= hotel.address || '' %></p>

        <% (hotel.nearby || []).forEach(function(place) { %>
            <div class="area-item">
                <span><%= place.name %></span>
                <span><%= place.distance %></span>
            </div>
        <% }) %>
    </div>

    <!-- Facilities -->
    <div>
        <div class="section-title">Main Facilities</div>

        <% (hotel.facilities || []).forEach(function(fac) { %>
            <div class="facility-item">
                <i class="fa-solid fa-<%= fac.icon || 'circle' %>"></i>
                <span><%= fac.name %></span>
            </div>
        <% }) %>

    </div>

</div>

</div>

</body>
</html>