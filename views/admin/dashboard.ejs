<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
</head>

<body style="
  margin:0;
  font-family:Arial;
  display:flex;
">

  <!-- SIDEBAR -->
  <div style="
    width:250px;
    height:100vh;
    background:#0f172a;
    color:white;
    padding:20px;
  ">

    <h2>ADMIN</h2>

    <div style="margin-top:30px; display:flex; flex-direction:column; gap:20px;">

      <a href="/admin"
         style="color:white; text-decoration:none;">
         Dashboard
      </a>

      <a href="/admin/hotels"
         style="color:white; text-decoration:none;">
         Hotels
      </a>

      <a href="/admin/airports"
         style="color:white; text-decoration:none;">
         Airports
      </a>

      <a href="/admin/users"
         style="color:white; text-decoration:none;">
         Users
      </a>

      <a href="/admin/bookings"
         style="color:white; text-decoration:none;">
         Bookings
      </a>

    </div>

  </div>

  <!-- CONTENT -->
  <div style="
    flex:1;
    padding:40px;
    background:#f1f5f9;
  ">

    <h1>Dashboard</h1>

    <div style="
      display:flex;
      gap:20px;
      margin-top:30px;
    ">

      <div style="
        background:white;
        padding:30px;
        border-radius:15px;
        width:250px;
      ">
        <h2>Hotels</h2>
        <h1><%= totalHotels %></h1>      </div>

      <div style="
        background:white;
        padding:30px;
        border-radius:15px;
        width:250px;
      ">
        <h2>Users</h2>
        <h1><%= totalUsers %></h1>   
       </div>

    </div>

  </div>

</body>
</html>