<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Traveloka Clone - Đặt chỗ & Vi vu</title>

  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" /> 
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background-color: #f7f9fa;
      color: #03121a;
      overflow-x: hidden; /* Tránh cuộn ngang */
    }

    /* Style cho Lịch */
    .flatpickr-calendar {
      border-radius: 15px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }

    /* Vùng chứa Form Email (để fix lỗi gạch đỏ VS Code cũ) */
    .d-none { display: none !important; }
  </style>
</head>
<body>

  <%- include('partials/header') %>

  <div style="width: 100%; padding: 30px 80px;">
  <div style="position: relative; border-radius: 20px; overflow: hidden;">
    
    <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e"
         style="width:100%; height:400px; object-fit:cover;">

    <div style="
      position: absolute;
      bottom: 50px;
      left: 0;
      width: 100%;
      padding: 40px;
      background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
      color: white;
    ">
      <h1 style="font-size:40px; font-weight:700;">
         Where to next? Book your next hotel for less
      </h1>
        <p style="font-size:18px; margin-top:10px;">
          Discover hotels, villas, resorts and more.
    
    </div>

  </div>
</div>

    <div style="
    width: 100%; 
    margin-top: -100px; 
    padding: 0 80px; 
    position: relative; 
    z-index: 10; 
    margin-bottom: 40px;">

      <div style="
      background: white; 
      padding: 30px; 
      border-radius: 25px; 
      box-shadow: 0 20px 50px rgba(0,0,0,0.15); 
      display: flex; 
      gap: 25px; 
      align-items: flex-end;">
        
        <div style="flex:1; display:flex; flex-direction:column; gap:6px; position:relative;">
          <div style="font-size:13px; color:#000000; font-weight: 600;">
            City, destination, or hotel name
          </div>

          <input id="searchInput" type="text" placeholder="City, hotel, place to go" style="
          width: 100%; 
          padding: 14px; 
          border-radius: 12px; 
          border: 1px solid #ddd; 
          font-size: 14px;">
          
          <div id="dropdown" style="
          position:absolute; 
          top:75px; 
          left:0; 
          width:130%; 
          background:white; 
          border-radius:12px; 
          box-shadow:0 15px 40px rgba(0,0,0,0.15); 
          display:none; 
          z-index:999; 
          max-height: 350px; 
          overflow-y: 
          auto;">
          </div>
        </div>

        <div style="flex:1; display:flex; flex-direction:column; gap:6px; position:relative;">
          <div style="font-size:13px; color:#000000; font-weight: 600;">Check-in & Check-out Dates</div>
          <input id="dateInput" type="text" placeholder="Select dates" style="width: 100%; padding: 14px; border-radius: 12px; border: 1px solid #ddd; font-size: 14px; cursor: pointer;">
        </div>

        <div style="flex:1; display:flex; flex-direction:column; gap:6px; position:relative;">
          <div style="font-size:13px; color:#000000; font-weight: 600;">Guests and Rooms</div>
          <input id="guestInput" readonly value="2 Adult(s), 0 Child, 1 Room" style="width: 100%; padding: 14px; border-radius: 12px; border: 1px solid #ddd; cursor: pointer; font-size: 14px;">
          
          <div id="guestDropdown" style="position:absolute; top: 75px; left:0; width:100%; background:white; border-radius:12px; box-shadow:0 15px 40px rgba(0,0,0,0.15); padding:20px; display:none; z-index:999;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;"><div style="font-weight: 600;">Adult</div><div style="display:flex; align-items:center; gap:12px;"><button onclick="change('adult', -1)" style="width: 28px; height: 28px; border: 1px solid #0194f3; color:#0194f3; border-radius: 4px; cursor: pointer; background: white; font-weight:bold;">-</button><span id="adult" style="min-width: 20px; text-align: center; font-weight:bold;">2</span><button onclick="change('adult', 1)" style="width: 28px; height: 28px; border: 1px solid #0194f3; color:#0194f3; border-radius: 4px; cursor: pointer; background: white; font-weight:bold;">+</button></div></div>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;"><div style="font-weight: 600;">Children</div><div style="display:flex; align-items:center; gap:12px;"><button onclick="change('child', -1)" style="width: 28px; height: 28px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">-</button><span id="child" style="min-width: 20px; text-align: center;">0</span><button onclick="change('child', 1)" style="width: 28px; height: 28px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">+</button></div></div>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;"><div style="font-weight: 600;">Room</div><div style="display:flex; align-items:center; gap:12px;"><button onclick="change('room', -1)" style="width: 28px; height: 28px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">-</button><span id="room" style="min-width: 20px; text-align: center;">1</span><button onclick="change('room', 1)" style="width: 28px; height: 28px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; background: white;">+</button></div></div>
            <div style="margin-top:15px; text-align:right;"><button onclick="closeGuest()" style="background:#0194f3; color:white; border:none; padding:8px 16px; border-radius:20px; cursor:pointer; font-weight: 600; font-size:13px;">Done</button></div>
          </div>
        </div>

        <div style="display:flex; align-items:flex-end;">
          <button style="background: #ff5e1f; color: white; border: none; padding: 15px 30px; border-radius: 40px; font-size: 16px; font-weight: 700; cursor: pointer; transition: background 0.3s;" onmouseover="this.style.background='#e04f1a'" onmouseout="this.style.background='#ff5e1f'">
            <i class="fa fa-search"></i> Search
          </button>
        </div>
      </div>
    </div>

    <div style="padding: 0 80px; margin-bottom: 50px;">
      <%- include('hotels/hotelLists') %>
    </div>

    <div id="email-forms-wrapper" class="<%= typeof formDisplayStyle !== 'undefined' && formDisplayStyle === 'none' ? 'd-none' : '' %>">
        </div>

  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // --- I. SCRIPT XỬ LÝ LỊCH (FLATPICKR) ---
      flatpickr("#dateInput", {
        mode: "range",
        dateFormat: "D, d M Y",
        minDate: "today",
        showMonths: 2,
        position: "below",
        static: false, // Để nó bay lên trên search box nếu cần
        theme: "material_blue" // Thêm theme cho đẹp
      });

      // --- II. SCRIPT XỬ LÝ TÌM KIẾM ĐỊA ĐIỂM (AJAX) ---
      const input = document.getElementById('searchInput');
      const dropdown = document.getElementById('dropdown');

      if (input && dropdown) {
          input.addEventListener('input', async () => {
              const q = input.value;
              if (!q) { dropdown.style.display = 'none'; return; }

              try {
                  const res = await fetch(`/locations/search?q=${q}`);
                  const data = await res.json();
                  if (data.length === 0) { dropdown.style.display = 'none'; return; }

                  dropdown.innerHTML = '';
                  data.forEach(loc => {
                      const item = document.createElement('div');
                      item.style.padding = '15px';
                      item.style.borderBottom = '1px solid #eee';
                      item.style.cursor = 'pointer';
                      item.style.display = 'flex';
                      item.style.justifyContent = 'space-between';
                      item.style.alignItems = 'center';

                      item.onmouseover = () => item.style.background = '#f5f7fa';
                      item.onmouseout = () => item.style.background = 'white';

                      item.innerHTML = `
                          <div>
                              <div style="font-weight:700; font-size:14px;">${loc.name}</div>
                              <div style="font-size:13px; color:#777; margin-top:4px;">${loc.description}, ${loc.country}</div>
                          </div>
                          <div style="text-align:right;">
                              <div style="background:#e6f0ff; color:#0071c2; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:bold; display:inline-block;">City</div>
                              <div style="font-size:12px; color:#666; margin-top:4px;">${loc.hotelsCount || 0} hotels</div>
                          </div>`;

                      item.onclick = () => { input.value = loc.name; dropdown.style.display = 'none'; };
                      dropdown.appendChild(item);
                  });
                  dropdown.style.display = 'block';
              } catch (error) { console.error('Lỗi tìm kiếm:', error); }
          });
      }

      // --- III. SCRIPT XỬ LÝ CHỌN KHÁCH & PHÒNG ---
      const guestInput = document.getElementById('guestInput');
      const guestDropdown = document.getElementById('guestDropdown');

      let state = { adult: 2, child: 0, room: 1 };

      if (guestInput && guestDropdown) {
          // Mở dropdown
          guestInput.onclick = (e) => { e.stopPropagation(); guestDropdown.style.display = 'block'; };
          // Đóng khi click Done
          window.closeGuest = () => { guestDropdown.style.display = 'none'; };
          // Đóng khi click ra ngoài
          document.addEventListener('click', (e) => {
              if (!guestDropdown.contains(e.target) && e.target !== guestInput) {
                  guestDropdown.style.display = 'none';
              }
          });
      }

      // Hàm thay đổi số lượng (Global function)
      window.change = function(type, value) {
          state[type] += value;
          // Giới hạn số lượng
          if (type === 'adult' && state[type] < 1) state[type] = 1; // Ít nhất 1 người lớn
          if (type !== 'adult' && state[type] < 0) state[type] = 0; // Trẻ em, phòng không âm

          // Cập nhật giao diện dropdown
          const el = document.getElementById(type);
          if (el) el.innerText = state[type];

          // Cập nhật giá trị input
          if (guestInput) {
              guestInput.value = `${state.adult} Adult(s), ${state.child} Child, ${state.room} Room`;
          }
      }
    });
  </script>

</body>
</html>